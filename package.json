{
  "name": "evs-telebot",
  "version": "1.0.0",
  "description": "EVS electricity top-up Telegram bot with eNETS payment WebApp",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run install:frontend && npm run build:frontend",
    "install:frontend": "npm ci --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "axios-cookiejar-support": "^6.0.5",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "marked": "^18.0.2",
    "posthog-node": "^5.29.7",
    "telegraf": "^4.16.3",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  }
}
